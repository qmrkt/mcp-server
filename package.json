{
  "name": "@question/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for question.market prediction markets on Algorand",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "question-mcp": "src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/__tests__/e2e/**'",
    "test:e2e": "vitest run src/__tests__/e2e"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@question/sdk": "^0.1.0",
    "algosdk": "^3.5.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.2",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qmrkt/mcp-server.git"
  },
  "license": "MIT",
  "author": "Andrei Savin <andrei@andreisavin.com>",
  "homepage": "https://question.market"
}
