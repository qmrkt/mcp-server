{
  "name": "@questionmarket/mcp",
  "version": "0.1.5",
  "description": "MCP server for question.market prediction markets on Algorand",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "question-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-deployments.mjs",
    "sync:deployments": "node ./scripts/sync-deployments.mjs",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --exclude 'src/__tests__/e2e/**'",
    "test:runtime": "node ./scripts/test-runtime-dist.mjs",
    "test:e2e": "vitest run src/__tests__/e2e",
    "test": "npm run build && npm run test:unit && npm run test:runtime",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run pack:check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@questionmarket/sdk": "^0.3.0",
    "algosdk": "^3.5.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qmrkt/mcp-server.git"
  },
  "license": "MIT",
  "author": "Andrei Savin <andrei@andreisavin.com>",
  "homepage": "https://question.market",
  "engines": {
    "node": ">=18"
  }
}
